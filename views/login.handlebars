<div class="login-page">
  <h1>Welcome to Brewery Search!</h1>
  <p>Please log in or sign up to continue.</p>
  <div class="container">
    <div class="col-sm-6 col-md-4" id="loginPanel">
      <form id="loginForm">
        <h2>Login</h2>

        <div id="loginError" class="error-message" aria-live="polite"></div>

        <div class="form-group">
          <input
            type="email"
            id="loginName"
            name="email"
            placeholder=" "
            autocomplete="email"
            required
          />
          <label for="loginName">Email:</label>
        </div>

        <div class="form-group password-group">
          <input
            type="password"
            id="loginPassword"
            name="password"
            placeholder=" "
            autocomplete="current-password"
            required
          />
          <label for="loginPassword">Password:</label>
          <button
            type="button"
            class="toggle-pass"
            data-target="#loginPassword"
          >Show</button>
        </div>

        <div class="form-group form-actions"><button
            type="submit"
            id="loginSubmit"
          >Login</button></div>
      </form>
    </div>
  </div>

  <div class="container">
    <div class="col-sm-6 col-md-4">
      <form id="signupForm">
        <h2>Sign Up</h2>

        <div id="signupError" class="error-message" aria-live="polite"></div>

        <div class="form-group">
          <input
            type="text"
            id="createName"
            name="name"
            placeholder=" "
            autocomplete="username"
            required
          />
          <label for="createName">Username:</label>
        </div>

        <div class="form-group">
          <input
            type="email"
            id="createEmail"
            name="email"
            placeholder=" "
            autocomplete="email"
            required
          />
          <label for="createEmail">Email:</label>
        </div>

        <div class="form-group password-group">
          <input
            type="password"
            id="createPassword"
            name="password"
            placeholder=" "
            autocomplete="new-password"
            required
          />
          <label for="createPassword">Password:</label>
          <button
            type="button"
            class="toggle-pass"
            data-target="#createPassword"
          >Show</button>
        </div>

        <div class="form-group form-actions"><button
            type="submit"
            id="signupSubmit"
          >Sign Up</button></div>
      </form>
    </div>
  </div>
</div>

<script src="/js/login.js"></script>