<div class='login-page mt-5'>
  <h1 class='login-title text-center mb-2'>Welcome to Brewery Search</h1>
  <h5 class='login-subtitle text-center mb-4'>Log in or create an account to continue</h5>

  <div class='auth-forms d-flex flex-wrap justify-content-center gap-5'>

    <!-- Login Form -->
    <form class='auth-form login-form p-4 border rounded'>
      <h2 class='form-title mb-3'>Login</h2>

      <div class='error-message login-error mb-2' aria-live='polite'></div>

      <div class='form-group mb-3'>
        <input
          type='email'
          name='email'
          class='form-input'
          placeholder='Email'
          autocomplete='email'
          required
        />
        <label>Email</label>
      </div>

      <div class='form-group password-group mb-3'>
        <input
          type='password'
          name='password'
          class='form-input password-input'
          placeholder='Password'
          autocomplete='current-password'
          required
        />
        <label>Password</label>
        <button type='button' class='toggle-pass' data-target='.password-input'>Show</button>
      </div>

      <button type='submit' class='btn btn-accent w-100'>Login</button>
    </form>

    <!-- Signup Form -->
    <form class='auth-form signup-form p-4 border rounded'>
      <h2 class='form-title mb-3'>Sign Up</h2>

      <div class='error-message signup-error mb-2' aria-live='polite'></div>

      <div class='form-group mb-3'>
        <input
          type='text'
          name='username'
          class='form-input'
          placeholder='Username'
          autocomplete='username'
          required
        />
        <label>Username</label>
      </div>

      <div class='form-group mb-3'>
        <input
          type='email'
          name='email'
          class='form-input'
          placeholder='Email'
          autocomplete='email'
          required
        />
        <label>Email</label>
      </div>

      <div class='form-group password-group mb-3'>
        <input
          type='password'
          name='password'
          class='form-input password-input'
          placeholder='Password'
          autocomplete='new-password'
          required
        />
        <label>Password</label>
        <button type='button' class='toggle-pass' data-target='.password-input'>Show</button>
      </div>

      <button type='submit' class='btn btn-success w-100'>Sign Up</button>
    </form>

  </div>
</div>