<div class="container">
  <div class="col-sm-3" id="loginPanel">
    <form id="loginForm">
      <h2>Login</h2>

      <div id="loginError" class="error-message"></div>

      <label>Email:</label>
      <p>
        <input
          type="email"
          id="loginName"
          name="email"
          placeholder="User Email"
        />
      </p>

      <label>Password:</label>
      <p>
        <input
          type="password"
          id="loginPassword"
          name="password"
          placeholder="User Password"
        />
        <button
          type="button"
          class="toggle-pass"
          data-target="#loginPassword"
        >Show</button>
      </p>

      <p><button type="submit" id="loginSubmit">Login</button></p>
    </form>
  </div>
</div>

<div class="container">
  <div class="col-sm-3">
    <form id="signupForm">
      <h2>Sign Up</h2>

      <div id="signupError" class="error-message"></div>

      <label>Username:</label>
      <p>
        <input
          type="text"
          id="createName"
          name="name"
          placeholder="Ex: bugle212"
        />
      </p>

      <label>Email:</label>
      <p>
        <input
          type="email"
          id="createEmail"
          name="email"
          placeholder="Your Email"
        />
      </p>

      <label>Password:</label>
      <p>
        <input
          type="password"
          id="createPassword"
          name="password"
          placeholder="Must be 6 characters"
        />
        <button
          type="button"
          class="toggle-pass"
          data-target="#createPassword"
        >Show</button>
      </p>

      <p><button type="submit" id="signupSubmit">Sign Up</button></p>
    </form>
  </div>
</div>

<script src="/js/login.js"></script>