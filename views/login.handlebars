<div class="login-page mt-5">
  <h1>Welcome to Brewery Search!</h1>
  <h5>Please log in or sign up to continue.</h5>

  <div class="d-flex flex-wrap justify-content-center gap-4">

    <!-- Login Form -->
    <form id="loginForm" class="p-3 border rounded" style="min-width: 300px;">
      <h2>Login</h2>

      <div id="loginError" class="error-message mb-2" aria-live="polite"></div>

      <div class="form-group mb-2">
        <input
          type="email"
          id="loginName"
          name="email"
          placeholder=" "
          autocomplete="email"
          required
        />
        <label for="loginName">Email:</label>
      </div>

      <div class="form-group password-group mb-2">
        <input
          type="password"
          id="loginPassword"
          name="password"
          placeholder=" "
          autocomplete="current-password"
          required
        />
        <label for="loginPassword">Password:</label>
        <button type="button" class="toggle-pass" data-target="#loginPassword">Show</button>
      </div>

      <div class="form-group form-actions">
        <button type="submit" id="loginSubmit" class="btn btn-primary w-100">
          Login
        </button>
      </div>
    </form>

    <!-- Signup Form -->
    <form id="signupForm" class="p-3 border rounded" style="min-width: 300px;">
      <h2>Sign Up</h2>

      <div id="signupError" class="error-message mb-2" aria-live="polite"></div>

      <div class="form-group mb-2">
        <input
          type="text"
          id="createName"
          name="name"
          placeholder=" "
          autocomplete="username"
          required
        />
        <label for="createName">Username:</label>
      </div>

      <div class="form-group mb-2">
        <input
          type="email"
          id="createEmail"
          name="email"
          placeholder=" "
          autocomplete="email"
          required
        />
        <label for="createEmail">Email:</label>
      </div>

      <div class="form-group password-group mb-2">
        <input
          type="password"
          id="createPassword"
          name="password"
          placeholder=" "
          autocomplete="new-password"
          required
        />
        <label for="createPassword">Password:</label>
        <button type="button" class="toggle-pass" data-target="#createPassword">Show</button>
      </div>

      <div class="form-group form-actions">
        <button type="submit" id="signupSubmit" class="btn btn-success w-100">
          Sign Up
        </button>
      </div>
    </form>

  </div>
</div>
