<section class="hero">
  <div class="hero-card brewery-card">
    <div class="hero-inner">
      <div class="hero-content">
        <h1>Find Local Breweries</h1>
        <p>Search by name, city, or state to discover your next favorite spot.</p>
      </div>

      <form id="search-form" class="search-form mt-4">
        <input type="text" name="name" placeholder="Brewery name" aria-label="Search by brewery name" class="form-input" />
        <input type="text" name="city" placeholder="City" aria-label="Search by city" class="form-input" />

        <!-- Custom State Select -->
        <div id="state-select" class="custom-inputs">
          <input type="text" class="custom-select-input" placeholder="State" autocomplete="off" />
          <input type="hidden" name="state" />
          <div class="custom-select-dropdown hidden"></div>
        </div>

        <button type="submit" class="btn btn-accent" id="search-btn">Search</button>
      </form>
    </div>
  </div>
</section>

{{#if apiData.length}}
<section class="results-section mt-5">
  <div class="results-header text-center mb-4">
    <h2>Search Results</h2>
  </div>

  <div class="brewery-grid">
    {{#each apiData as |brewery|}}
    <article class="brewery-card">
      <div class="card-top">
        <div class="spacer">
        <h2 class="web-url">
          <a
            href="{{breweryExternalUrl brewery.website_url brewery.name brewery.city brewery.state}}"
            target="_blank"
            rel="noopener noreferrer"
            class="brewery-name visit-btn"
          >
            {{brewery.name}}
          </a>
        </h2>
        {{#if brewery.brewery_type}}
        <span class="badge">{{brewery.brewery_type}}</span>
        {{/if}}
      </div>

      <div class="card-content">
        {{#if brewery.latitude}}
        <button
          type="button"
          class="location-link"
          data-name="{{brewery.name}}"
          data-lat="{{brewery.latitude}}"
          data-lng="{{brewery.longitude}}"
        >
          {{#if brewery.street}}{{brewery.street}}{{else}}{{brewery.address_1}}{{/if}}<br />
          {{brewery.city}}, {{brewery.state}} {{brewery.postal_code}}
        </button>
        {{else}}
        <p class="location-link">
          {{#if brewery.street}}{{brewery.street}}{{else}}{{brewery.address_1}}{{/if}}<br />
          {{brewery.city}}, {{brewery.state}} {{brewery.postal_code}}
        </p>
        {{/if}}

        <p class="phone mb-2">
          Phone:&nbsp;
          {{#if brewery.phone}}
          <a href="{{phoneLink brewery.phone}}">{{formatPhone brewery.phone}}</a>
          {{else}}
          N/A
          {{/if}}
        </p>
      </div>
      </div>

      <div class="card-actions">
        {{#if brewery.website_url}}
        <a
          href="{{brewery.website_url}}"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sm btn-outline-primary visit-btn"
        >
          Visit Website
        </a>
        {{/if}}

        <a
          href="{{yelpUrl brewery.name brewery.city brewery.state}}"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sm btn-outline-primary visit-btn yelp-btn"
        >
          See Reviews
        </a>

        <button
          class="btn-save-brewery save-btn btn btn-accent"
          data-id="{{brewery.id}}"
          data-name="{{brewery.name}}"
          data-address="{{#if brewery.street}}{{brewery.street}}{{else}}{{brewery.address_1}}{{/if}}"
          data-city="{{brewery.city}}"
          data-state="{{brewery.state}}"
          data-zip="{{brewery.postal_code}}"
          data-phone="{{formatPhone brewery.phone}}"
          data-website="{{brewery.website_url}}"
          data-lat="{{brewery.latitude}}"
          data-lng="{{brewery.longitude}}"
          data-type="{{brewery.brewery_type}}"
        >
          Save Brewery
        </button>

        {{#if brewery.latitude}}
        <button
          class="btn-map-brewery btn btn-success"
          data-name="{{brewery.name}}"
          data-lat="{{brewery.latitude}}"
          data-lng="{{brewery.longitude}}"
        >
          View Map
        </button>
        {{/if}}
      </div>
    </article>
    {{/each}}
  </div>
  </div>

</section>
{{/if}}

<!-- Map Modal -->
<div id="map-modal" class="modal hidden">
  <div class="modal-content">
    <button class="modal-close" id="close-map">&times;</button>
    <div id="modal-map"></div>
  </div>
</div>