<section class="hero">
  <div class="hero-content">
    <h1>Discover Local Breweries 🍺</h1>
    <p>Search any city and explore craft beer spots near you</p>

    <form id="search-form" class="search-form">
      <input type="text" id="city" placeholder="Enter a city" required />
      <button type="submit">Search</button>
    </form>
  </div>
</section>

<section class="results-section">

  {{#if apiData.length}}
    <div class="results-header">
      <h2>Breweries Found</h2>
    </div>

    <div class="brewery-grid">
      {{#each apiData}}
        <div class="brewery-card">

          <div class="card-top">
            <h3>{{this.name}}</h3>
            <span class="badge">{{this.brewery_type}}</span>
          </div>

          <p class="location">
            📍
            {{this.city}},
            {{this.state}}
          </p>

          {{#if this.website_url}}
            <a href="{{this.website_url}}" target="_blank" class="visit-btn">
              Visit Website
            </a>
          {{/if}}

          <div class="card-actions">
            <button
              type="button"
              class="btn-save-brewery save-btn"
              data-id="{{id}}"
              data-name="{{name}}"
              data-city="{{city}}"
              data-state="{{state}}"
              data-address="{{address_1}}"
              data-zip="{{postal_code}}"
              data-phone="{{phone}}"
              data-website="{{website_url}}"
              data-lat="{{latitude}}"
              data-lng="{{longitude}}"
              data-type="{{brewery_type}}"
            >
              ⭐ Save
            </button>

            {{#if this.latitude}}
              <button
                type="button"
                class="btn-map-brewery save-btn"
                data-name="{{name}}"
                data-lat="{{latitude}}"
                data-lng="{{longitude}}"
              >
                📍 View Map
              </button>
            {{/if}}
          </div>

        </div>
      {{/each}}
    </div>

  {{else}}
    <div class="empty-state">
      <h2>No breweries yet</h2>
      <p>Search a city above to get started 🍺</p>
    </div>
  {{/if}}

</section>

<!-- Map Modal -->
<div id="map-modal" class="modal hidden">
  <div class="modal-content">
    <button class="modal-close" id="close-map">&times;</button>
    <div id="modal-map"></div>
  </div>
</div>

<script src="/js/homepage.js"></script>