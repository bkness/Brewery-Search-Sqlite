<section class="hero">
  <div class="hero-content">
    <h1>Find Local Breweries</h1>
    <p>Search by name, city, or state to discover your next favorite spot.</p>
  </div>

  <form id="search-form" class="search-form mt-4">
    <input
      type="text"
      name="name"
      placeholder="Brewery name"
      aria-label="Search by brewery name"
    />

    <input
      type="text"
      name="city"
      placeholder="City"
      aria-label="Search by city"
    />

    <!-- Custom State Select -->
    <div id="state-select" class="custom-select">
      <input
        type="text"
        class="custom-select-input"
        placeholder="State"
        autocomplete="off"
      />
      <input type="hidden" name="state" />
      <div class="custom-select-dropdown hidden"></div>
    </div>

    <button type="submit">Search</button>
  </form>
</section>

{{#if apiData.length}}
<section class="results-section mt-5">
  <div class="results-header text-center mb-4">
    <h2>Search Results</h2>
  </div>

  <div class="brewery-grid">
    {{#each apiData as |brewery|}}
      <article class="brewery-card">
        <div class="card-header">
          <h2 class="brew-name">{{brewery.name}}</h2>
          {{#if brewery.brewery_type}}
            <span class="badge">{{brewery.brewery_type}}</span>
          {{/if}}
        </div>

        <p class="brew-location">
          {{brewery.street}}<br />
          {{brewery.city}}, {{brewery.state}} {{brewery.postal_code}}
        </p>

        {{#if brewery.phone}}
          <p class="brew-location">
            <a href="tel:+1{{brewery.phone}}">{{brewery.phone}}</a>
          </p>
        {{/if}}

        {{#if brewery.website_url}}
          <a
            href="{{brewery.website_url}}"
            target="_blank"
            rel="noopener noreferrer"
            class="visit-btn btn btn-sm btn-outline-primary"
          >
            Visit Website
          </a>
        {{/if}}

        <div class="card-actions mt-3">
          <button
            class="btn-save-brewery btn btn-warning"
            data-id="{{brewery.id}}"
            data-name="{{brewery.name}}"
            data-address="{{brewery.street}}"
            data-city="{{brewery.city}}"
            data-state="{{brewery.state}}"
            data-zip="{{brewery.postal_code}}"
            data-phone="{{brewery.phone}}"
            data-website="{{brewery.website_url}}"
            data-lat="{{brewery.latitude}}"
            data-lng="{{brewery.longitude}}"
            data-type="{{brewery.brewery_type}}"
          >
            Save Brewery
          </button>

          {{#if brewery.latitude}}
            <button
              class="btn-map-brewery btn btn-success"
              data-name="{{brewery.name}}"
              data-lat="{{brewery.latitude}}"
              data-lng="{{brewery.longitude}}"
            >
              View Map
            </button>
          {{/if}}
        </div>
      </article>
    {{/each}}
  </div>
</section>
{{/if}}

<!-- Map Modal -->
<div id="map-modal" class="modal hidden">
  <div class="modal-content">
    <button class="modal-close" id="close-map">&times;</button>
    <div id="modal-map"></div>
  </div>
</div>
