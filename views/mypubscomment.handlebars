<section class="single-brewery-page mt-5">

  <!-- Brewery Name -->
  <h1 class="text-center mb-4">{{brewery.brewname}}</h1>

  <!-- Brewery Details -->
  <div class="brewery-details-card p-4 border rounded">
    <p><strong>Address:</strong><br>
      {{brewery.address}}<br>
      {{brewery.city}}, {{brewery.state}} {{brewery.zipcode}}
    </p>

    {{#if brewery.phone}}
      <p><strong>Phone:</strong> <a href="tel:+1{{brewery.phone}}">{{brewery.phone}}</a></p>
    {{/if}}

    {{#if brewery.website}}
      <p>
        <strong>Website:</strong>
        <a href="{{brewery.website}}" target="_blank" rel="noopener noreferrer">
          Visit Website
        </a>
      </p>
    {{/if}}

    <div class="mt-3">
      <button
        class="btn btn-success btn-map-brewery"
        data-name="{{brewery.brewname}}"
        data-lat="{{brewery.latitude}}"
        data-lng="{{brewery.longitude}}"
      >
        View Map
      </button>
    </div>
  </div>

  <!-- Comments Section -->
  <section class="comments-section mt-5">
    <h3>Your Notes</h3>

    {{#if brewery.comment}}
      <div class="existing-comment p-3 mb-3 border rounded">
        <p>{{brewery.comment}}</p>
      </div>
    {{/if}}

    <textarea
      id="pubcomment"
      class="form-control mb-3"
      placeholder="Add a comment..."
      rows="3"
    ></textarea>

    <button id="pubcommentsubmit" class="btn btn-primary">Save Comment</button>
  </section>

  <!-- Delete Brewery -->
  <div class="mt-4">
    <button id="deletebrewery" class="btn btn-danger">Remove Brewery</button>
  </div>

  <!-- Hidden Brewery ID (required for JS) -->
  <input type="hidden" id="brewid" value="{{brewery.id}}" />

</section>

<!-- Map Modal -->
<div id="map-modal" class="modal hidden">
  <div class="modal-content">
    <button class="modal-close" id="close-map">&times;</button>
    <div id="modal-map"></div>
  </div>
</div>
