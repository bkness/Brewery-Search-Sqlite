<section class='results-section single-pub-page'>
  <article class='brewery-card single-pub-card' data-id='{{brewery.
<input type="hidden" id="brewid" value="{{brewery.id}}" />
    <div class='card-top'>
      <h1 class='commenting-card'>{{brewery.name}}</h1>
      {{#if brewery.remark}}<span class='badge'>{{brewery.remark}}</span>{{/if}}
    </div>

    <h5 class='location'>{{brewery.address}}</h5>
    <h5 class='location'>{{brewery.city}}, {{brewery.state}} {{brewery.zipcode}}</h5>

    <h5 class='location'>
      <strong>Phone:</strong>
      {{#if brewery.phone}}
        <a href='tel:+1{{brewery.phone}}'>{{brewery.phone}}</a>
      {{else}}
        <span class='muted-copy'>No phone number available</span>
      {{/if}}
    </h5>

    <h5 class='location'>
      <strong>Website:</strong>
      {{#if brewery.website}}
        <a href='{{brewery.website}}' target='_blank' rel='noopener noreferrer'>
          {{brewery.website}}
        </a>
      {{else}}
        <span class='muted-copy'>No website available</span>
      {{/if}}
    </h5>

    <div class='pubcomment single-pub-comment'>
      <label for='pubcomment'>Comment:</label>
      <textarea class='input' id='pubcomment'></textarea>
      <button id='pubcommentsubmit' type='submit' class='save-btn'>Submit Comment</button>
    </div>

    <div class='single-pub-actions'>
      <button id='deletebrewery' type='submit' class='save-btn'>Remove Brewery</button>
      <p class='single-pub-note'>
        If you no longer want to keep this brewery in your list, remove it here.
      </p>
    </div>
  </article>
</section>
