<section class="results-section mt-5">
  {{#if apiData.length}}
    <div class="results-header text-center mb-4">
      <h2>Breweries in {{searchCity}}</h2>
    </div>

    <div class="brewery-grid">
      {{#each apiData}}
        <article class="brewery-card">
          <div class="card-header">
            <h2 class="brew-name">{{this.name}}</h2>
            {{#if this.brewery_type}}
              <span class="badge">{{this.brewery_type}}</span>
            {{/if}}
          </div>

          <p class="brew-location">
            {{this.street}}<br />
            {{this.city}}, {{this.state}} {{this.postal_code}}
          </p>

          {{#if this.phone}}
            <p class="brew-location">
              <a href="tel:+1{{this.phone}}">{{this.phone}}</a>
            </p>
          {{/if}}

          {{#if this.website_url}}
            <a
              href="{{this.website_url}}"
              target="_blank"
              rel="noopener noreferrer"
              class="visit-btn btn btn-sm btn-outline-primary"
            >
              Visit Website
            </a>
          {{/if}}

          <div class="card-actions mt-3">
            <button
              class="btn-save-brewery btn btn-warning"
              data-id="{{id}}"
              data-name="{{name}}"
              data-address="{{street}}"
              data-city="{{city}}"
              data-state="{{state}}"
              data-zip="{{postal_code}}"
              data-phone="{{phone}}"
              data-website="{{website_url}}"
              data-lat="{{latitude}}"
              data-lng="{{longitude}}"
              data-type="{{brewery_type}}"
              {{#if (includes ../savedIds id)}}disabled style="opacity:0.6"{{/if}}
            >
              {{#if (includes ../savedIds id)}}Saved ✓{{else}}Save Brewery{{/if}}
            </button>

            {{#if latitude}}
              <button
                class="btn-map-brewery btn btn-success"
                data-name="{{name}}"
                data-lat="{{latitude}}"
                data-lng="{{longitude}}"
              >
                View Map
              </button>
            {{/if}}
          </div>
        </article>
      {{/each}}
    </div>

  {{else}}
    <div class="empty-state text-center">
      <h2>No breweries found in {{searchCity}}</h2>
      <p>Try searching another city 🍺</p>
    </div>
  {{/if}}
</section>

<!-- Map Modal -->
<div id="map-modal" class="modal hidden">
  <div class="modal-content">
    <button class="modal-close" id="close-map">&times;</button>
    <div id="modal-map"></div>
  </div>
</div>
